{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbor",
  "version": "2.0.1",
  "identifier": "com.eduard-lt.harbor",
  "build": {
    "beforeBuildCommand": "npm run build --prefix ../packages/ui",
    "beforeDevCommand": "npm run dev --prefix ../packages/ui",
    "devUrl": null,
    "frontendDist": "../../packages/ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Harbor",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "visible": false,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' https://api.github.com; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' asset: https://asset.localhost;",
      "capabilities": [
        "main"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "26.5",
      "dmg": {
        "background": "dmg_background.png",
        "windowSize": {
          "width": 660,
          "height": 480
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}